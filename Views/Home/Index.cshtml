@{
    ViewData["Title"] = "Panel de Control";
}

<div class="text-center mb-5">
    <h1 class="display-4">Agencia de Automóviles</h1>
    <p class="lead">Sistema de Control de Mantenimiento Preventivo y Correctivo</p>
</div>

<div class="container">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill display-1 text-primary"></i>
                    <h5 class="card-title mt-3">Clientes</h5>
                    <p class="card-text">Gestión del padrón de dueños de vehículos.</p>
                    <a href="/Cliente/Index" class="btn btn-primary w-100">Ver Clientes</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-body text-center">
                    <i class="bi bi-car-front-fill display-1 text-success"></i>
                    <h5 class="card-title mt-3">Vehículos</h5>
                    <p class="card-text">Control de inventario y datos técnicos de autos.</p>
                    <a href="/Vehiculo/Index" class="btn btn-success w-100">Ver Vehículos</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-info bg-light">
                <div class="card-body text-center">
                    <i class="bi bi-tools display-1 text-info"></i>
                    <h5 class="card-title mt-3 text-info">Gestión de Servicios</h5>
                    <p class="card-text">Módulo de mantenimiento y órdenes de trabajo.</p>
                    <a href="/Servicio/Index" class="btn btn-info text-white w-100">Ver Servicios</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-secondary">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">Configuración de Catálogos</h5>
                        <small class="text-muted">Administra marcas y modelos disponibles.</small>
                    </div>
                    <div class="btn-group">
                        <a href="/Marca/Index" class="btn btn-outline-secondary">Marcas</a>
                        <a href="/Modelo/Index" class="btn btn-outline-secondary">Modelos</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-dark">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">Tablero de Control</h5>
                        <small class="text-muted">Estado de solicitudes y gráficas.</small>
                    </div>
                    <button class="btn btn-dark disabled">Ver Dashboard</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}