@model IEnumerable<AgenciaMVC1.Models.Modelo>

<h2>Catálogo de Modelos</h2>

<a href="/Modelo/Crear" class="btn btn-success mb-3">Agregar Nuevo Modelo</a>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Año</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdModelo</td>
                <td>@item.MarcaVehiculo.Nombre</td>
                <td>@item.Nombre</td>
                <td>@item.Anio</td>
                <td>
                    <a href="/Modelo/Editar/@item.IdModelo" class="btn btn-sm btn-primary">Editar</a>
                    <a href="/Modelo/Eliminar/@item.IdModelo" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>