@model AgenciaMVC1.Models.Servicio
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Ticket_#@Model.Folio</title>
    <style>
        body {
            font-family: 'Courier New', Courier, monospace;
            width: 80mm;
            margin: 0 auto;
            padding: 15px;
            border: 1px solid #eee;
            font-size: 0.85em;
        }

        .header {
            text-align: center;
            border-bottom: 1px dashed #000;
            margin-bottom: 10px;
            padding-bottom: 8px;
        }

        .fila {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
        }

            .fila span:first-child {
                flex: 1;
                padding-right: 8px;
            }

            .fila span:last-child {
                white-space: nowrap;
            }

        .total {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
            font-size: 1.1em;
            margin-top: 6px;
        }

        hr {
            border-top: 1px dashed #000;
        }

        .centrado {
            text-align: center;
        }

        @@media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body onload="window.print()">

    <div class="header">
        <h5 style="margin:0;">AGENCIA DE AUTOS</h5>
        <p style="margin:4px 0;">ORDEN DE SERVICIO #@Model.Folio.ToString("D4")</p>
    </div>

    <p><strong>Fecha:</strong> @Model.FechaIngreso.ToShortDateString()</p>
    <p><strong>Cliente:</strong> @Model.VehiculoAtendido.Dueño.Nombre @Model.VehiculoAtendido.Dueño.Apellido</p>
    <p><strong>Auto:</strong> @Model.VehiculoAtendido.Placa</p>
    <p><strong>Entregado por:</strong> @Model.QuienEntrego</p>
    <p><strong>Estatus:</strong> @Model.Estatus</p>

    <hr />

    <h6>Detalle de Refacciones:</h6>

    @if (Model.Refacciones.Any())
    {
        @foreach (var item in Model.Refacciones)
        {
            <div class="fila">
                <span>@item.Cantidad x @item.RefaccionUtilizada.Nombre</span>
                <span>$@item.PrecioAplicado.ToString("0.00")</span>
            </div>
        }
    }
    else
    {
        <p style="color: gray;">Sin refacciones registradas.</p>
    }

    <hr />

    <div class="total">
        <span>TOTAL:</span>
        <span>$@Model.Refacciones.Sum(r => r.PrecioAplicado).ToString("0.00")</span>
    </div>

    <div class="centrado" style="margin-top: 20px;">
        <p>_______________________</p>
        <p style="font-size:0.8em;">Firma del Cliente</p>
        <p style="font-size:0.8em; color: gray;">¡Gracias por su preferencia!</p>
    </div>

    <div class="centrado no-print" style="margin-top: 12px;">
        <button onclick="window.close()" style="font-family: 'Courier New'; padding: 6px 16px;">Cerrar Ventana</button>
    </div>

</body>
</html>