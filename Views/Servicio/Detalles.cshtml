@model AgenciaMVC1.Models.Servicio

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Detalles de la Orden #@Model.Folio.ToString("D4")</h2>
    <div>
        <a href="/Servicio/Ticket/@Model.Folio" target="_blank" class="btn btn-outline-dark me-2">
            Imprimir Comprobante
        </a>
        <a href="/Servicio/Index" class="btn btn-secondary">Regresar a la lista</a>
    </div>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Información del Vehículo y Cliente</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-6">
                        <p class="text-muted mb-1">Vehículo (Placa)</p>
                        <h5>@Model.VehiculoAtendido.Placa</h5>
                        <p>
                            <strong>Color:</strong> @Model.VehiculoAtendido.Color <br />
                            <strong>Kilometraje:</strong> @Model.VehiculoAtendido.KmActual.ToString("N0") km
                        </p>
                    </div>
                    <div class="col-sm-6">
                        <p class="text-muted mb-1">Dueño del Auto</p>
                        <h5>@Model.VehiculoAtendido.Dueño.Nombre @Model.VehiculoAtendido.Dueño.Apellido</h5>
                        <p>
                            <strong>Teléfono:</strong> @Model.VehiculoAtendido.Dueño.Telefono <br />
                            <strong>Entregado por:</strong> @Model.QuienEntrego
                        </p>
                    </div>
                </div>
                <hr />
                <p class="text-muted mb-1">Descripción del Problema/Servicio</p>
                <p class="lead">@Model.Descripcion</p>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm mb-4 border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Gestión de Estatus</h5>
            </div>
            <div class="card-body text-center">
                <h6 class="text-muted">Estatus Actual:</h6>
                <h3 class="mb-4">
                    @if (Model.Estatus.ToString() == "EnEspera")
                    {
                        <span class="badge bg-secondary">En Espera</span>
                    }
                    else if (Model.Estatus.ToString() == "EnProceso")
                    {
                        <span class="badge bg-warning text-dark">En Proceso</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Finalizado</span>
                    }
                </h3>

                @if (Model.Estatus.ToString() != "Finalizado")
                {
                    <form asp-action="ActualizarEstatus" method="post" class="d-grid gap-2">
                        <input type="hidden" name="folio" value="@Model.Folio" />

                        @if (Model.Estatus.ToString() == "EnEspera")
                        {
                            <input type="hidden" name="nuevoEstatus" value="EnProceso" />
                            <button type="submit" class="btn btn-warning">Iniciar Trabajo (Pasar a En Proceso)</button>
                        }
                        else if (Model.Estatus.ToString() == "EnProceso")
                        {
                            <input type="hidden" name="nuevoEstatus" value="Finalizado" />
                            <button type="submit" class="btn btn-success">Marcar como Finalizado</button>
                        }
                    </form>
                }
                else
                {
                    <div class="alert alert-success">Este vehículo ya ha sido entregado/finalizado.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4 border-info">
    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Refacciones y Materiales Utilizados</h5>
        <h5 class="mb-0">Total Piezas: $@Model.Refacciones.Sum(r => r.PrecioAplicado).ToString("0.00")</h5>
    </div>
    <div class="card-body">

        @if (Model.Estatus.ToString() != "Finalizado")
        {
            <form asp-action="AgregarRefaccion" method="post" class="row g-3 mb-4 bg-light p-3 rounded">
                <input type="hidden" name="folio" value="@Model.Folio" />

                <div class="col-md-7">
                    <label class="form-label fw-bold">Seleccionar Pieza</label>
                    <select name="idRefaccion" class="form-select" asp-items="ViewBag.CatalogoRefacciones" required>
                        <option value="">-- Buscar en inventario --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Cantidad</label>
                    <input type="number" name="cantidad" class="form-control" value="1" min="1" required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Agregar</button>
                </div>
            </form>
        }

        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Descripción de la Pieza</th>
                    <th>Cantidad</th>
                    <th>Total Cobrado</th>
                    @if (Model.Estatus.ToString() != "Finalizado")
                    {
                        <th>Quitar</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Refacciones.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted">No se han agregado refacciones a este servicio.</td></tr>
                }
                @foreach (var r in Model.Refacciones)
                {
                    <tr>
                        <td>@r.RefaccionUtilizada.Codigo</td>
                        <td>@r.RefaccionUtilizada.Nombre</td>
                        <td>@r.Cantidad uds.</td>
                        <td>$@r.PrecioAplicado.ToString("0.00")</td>

                        @if (Model.Estatus.ToString() != "Finalizado")
                        {
                            <td>
                                <form asp-action="EliminarRefaccion" method="post" style="display:inline;">
                                    <input type="hidden" name="folio" value="@Model.Folio" />
                                    <input type="hidden" name="idRefaccion" value="@r.IdRefaccion" />
                                    <button type="submit" class="btn btn-sm btn-danger">X</button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>