@model AgenciaMVC1.Models.Vehiculo

<div class="card shadow-sm mx-auto" style="max-width: 700px;">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Nuevo Registro de Vehículo</h4>
    </div>
    <div class="card-body">
        <form asp-action="Crear" method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Dueño (Cliente)</label>
                    <select asp-for="IdCliente" class="form-control" asp-items="ViewBag.Clientes" required>
                        <option value="">Seleccione al dueño...</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Modelo de Auto</label>
                    <select asp-for="IdModelo" class="form-control" asp-items="ViewBag.Modelos" required>
                        <option value="">Seleccione marca/modelo...</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Placas</label>
                    <input type="text" asp-for="Placa" class="form-control" placeholder="ABC-123" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Color</label>
                    <select asp-for="Color" class="form-control" required>
                        <option value="">-- Seleccione --</option>
                        <option value="Blanco">Blanco</option>
                        <option value="Negro">Negro</option>
                        <option value="Plata">Plata</option>
                        <option value="Gris">Gris</option>
                        <option value="Rojo">Rojo</option>
                        <option value="Azul">Azul</option>
                        <option value="Verde">Verde</option>
                        <option value="Amarillo">Amarillo</option>
                        <option value="Naranja">Naranja</option>
                        <option value="Café">Café</option>
                        <option value="Beige">Beige</option>
                        <option value="Morado">Morado</option>
                        <option value="Dorado">Dorado</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Kilometraje</label>
                    <input type="number" asp-for="KmActual" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Número de Serie (VIN)</label>
                <input type="text" asp-for="NumSerie" class="form-control" required />
            </div>

            <hr />
            <button type="submit" class="btn btn-success px-4">Guardar Vehículo</button>
            <a href="/Vehiculo/Index" class="btn btn-link text-secondary">Cancelar</a>
        </form>
    </div>
</div>