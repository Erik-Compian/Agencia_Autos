@model AgenciaMVC1.Models.Refaccion

<div class="card shadow-sm mx-auto mt-4" style="max-width: 500px;">
    <div class="card-body">
        <h4 class="card-title mb-4">Datos de la Refacción</h4>

        <form asp-action="@(Model == null || Model.IdRefaccion == 0 ? "Crear" : "Editar")" method="post">
            @if (Model != null)
            {
                <input type="hidden" asp-for="IdRefaccion" />
            }

            <div class="mb-3">
                <label class="form-label">Código de Barras/SKU</label>
                <input type="text" asp-for="Codigo" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre de la Pieza</label>
                <input type="text" asp-for="Nombre" class="form-control" required />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Precio ($)</label>
                    <input type="number" asp-for="Precio" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Stock Actual</label>
                    <input type="number" asp-for="Stock" class="form-control" required />
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success">Guardar Pieza</button>
                <a href="/Refaccion/Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>