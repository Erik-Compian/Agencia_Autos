@model IEnumerable<AgenciaMVC1.Models.Refaccion>

<div class="d-flex justify-content-between mb-3">
    <h2>Inventario de Refacciones</h2>
    <a href="/Refaccion/Crear" class="btn btn-primary">Agregar Nueva Pieza</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre de la Pieza</th>
            <th>Precio Unitario</th>
            <th>Stock Disponible</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Codigo</strong></td>
                <td>@item.Nombre</td>
                <td>$@item.Precio.ToString("0.00")</td>
                <td>
                    <span class="badge @(item.Stock > 5 ? "bg-success" : "bg-danger")">
                        @item.Stock uds.
                    </span>
                </td>
                <td>
                    <a href="/Refaccion/Editar/@item.IdRefaccion" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a href="/Refaccion/Eliminar/@item.IdRefaccion" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>