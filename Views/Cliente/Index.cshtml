@model IEnumerable<AgenciaMVC1.Models.Cliente>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Clientes</h2>
    <a href="/Cliente/Crear" class="btn btn-primary">Registrar Nuevo Cliente</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Nombre Completo</th>
            <th>Teléfono</th>
            <th>Email</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre @item.Apellido</td>
                <td>@item.Telefono</td>
                <td>@item.Email</td>
                <td>
                    <a href="/Cliente/Editar/@item.IdCliente" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a href="/Cliente/Eliminar/@item.IdCliente" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>